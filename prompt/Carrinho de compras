const express = require('express');
const app = express();
const PORT = 3000;

// Middleware para permitir que o Express entenda requisições em formato JSON
app.use(express.json());

// Banco de dados temporário (em memória) para simular os produtos da loja
const produtos = [
    { id: 1, nome: "Fone de Ouvido Bluetooth Sem Fio", preco: 49.90 },
    { id: 2, nome: "Relógio Inteligente Smartwatch Sport", preco: 129.90 },
    { id: 3, nome: "Cabo USB Tipo-C Carregamento Rápido", preco: 15.99 },
    { id: 4, nome: "Mochila Impermeável Antifurto USB", preco: 89.90 }
];

// O estado do carrinho de compras (salvo em memória para esta sessão)
let carrinho = [];

// 1. Rota para listar todos os produtos disponíveis
app.get('/produtos', (req, res) => {
    res.json(produtos);
});

// 2. Rota para visualizar o estado atual do carrinho e o valor total
app.get('/carrinho', (req, res) => {
    const total = carrinho.reduce((acc, item) => acc + (item.preco * item.quantidade), 0);
    
    res.json({
        itens: carrinho,
        valorTotal: Number(total.toFixed(2))
    });
});

// 3. Rota para adicionar um produto ao carrinho (ou aumentar quantidade se já existir)
app.post('/carrinho/adicionar', (req, res) => {
    const { produtoId } = req.body;

    // Verifica se o produto existe no "banco de dados"
    const produto = produtos.find(p => p.id === Number(produtoId));
    if (!produto) {
        return res.status(404).json({ erro: "Produto não encontrado." });
    }

    // Verifica se o produto já está no carrinho
    const itemExistente = carrinho.find(item => item.id === Number(produtoId));

    if (itemExistente) {
        itemExistente.quantidade += 1;
    } else {
        carrinho.push({ ...produto, quantidade: 1 });
    }

    res.json({ mensagem: "Produto adicionado com sucesso!", carrinho });
});

// 4. Rota para alterar a quantidade ou remover um item do carrinho
app.put('/carrinho/alterar', (req, res) => {
    const { produtoId, acao } = req.body; // 'acao' pode ser 'aumentar' ou 'diminuir'

    const item = carrinho.find(item => item.id === Number(produtoId));
    if (!item) {
        return res.status(404).json({ erro: "Item não encontrado no carrinho." });
    }

    if (acao === 'aumentar') {
        item.quantidade += 1;
    } else if (acao === 'diminuir') {
        item.quantidade -= 1;
        // Se a quantidade chegar a zero, remove o item do carrinho
        if (item.quantidade <= 0) {
            carrinho = carrinho.filter(i => i.id !== Number(produtoId));
        }
    } else {
        return res.status(400).json({ erro: "Ação inválida. Use 'aumentar' ou 'diminuir'." });
    }

    res.json({ mensagem: "Quantidade atualizada!", carrinho });
});

// 5. Rota para limpar o carrinho (simulando a finalização da compra)
app.post('/carrinho/finalizar', (req, res) => {
    if (carrinho.length === 0) {
        return res.status(400).json({ erro: "O carrinho está vazio." });
    }

    carrinho = [];
    res.json({ mensagem: "Compra finalizada com sucesso! Carrinho limpo." });
});

// Inicialização do servidor na porta configurada
app.listen(PORT, () => {
    console.log(`Servidor rodando em http://localhost:${PORT}`);
});
